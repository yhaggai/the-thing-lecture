---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import CrtTerminal from "../components/CrtTerminal.astro";
import Itinerary from "../components/Itinerary.astro";
import Lecturer from "../components/Lecturer.astro";
import Characters from "../components/Characters.astro";
import TrailerModal from "../components/TrailerModal.astro";
---

<Layout 
	title="אאוטפוסט 31 | הקרנת THE THING והרצאת עומק"
	description="הצטרפו להקרנה והרצאת עומק של הסרט The Thing (1982) באאוטפוסט 31. הקרנת עותק ארכיוני מיוחד של 35 מ״מ ולאחריה הרצאה עם שאלות ותשובות מאת חגי יניב."
>
	<!-- Main Content Canvas -->
	<main class="flex-grow w-full max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-8 flex flex-col gap-8 relative z-10 bg-surface">
		
		<!-- Hero Section & Event Overview -->
		<Hero />
		

		<!-- Characters Dossier Carousel -->
		<Characters />

				<!-- Lecturer Biography & Details -->
		<Lecturer />


		<!-- Screening & Lecture Schedule Log -->
		<Itinerary />

				<!-- Interactive Outpost 31 Retro Command Center & RSVP Station -->
		<CrtTerminal />



	</main>

	<!-- Global CRT Trailer Playback Feed Modal -->
	<TrailerModal />
</Layout>

