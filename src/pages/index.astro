---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import CrtTerminal from "../components/CrtTerminal.astro";
import Itinerary from "../components/Itinerary.astro";
import Lecturer from "../components/Lecturer.astro";
import TrailerModal from "../components/TrailerModal.astro";
---

<Layout 
	title="סדרת סרטי אאוטפוסט 31 - הקרנת THE THING והרצאה"
	description="הצטרפו אלינו באאוטפוסט 31 להקרנה מיוחדת של עותק ארכיוני 35 מ״מ של הקלאסיקה של ג׳ון קרפנטר משנת 1982 The Thing, ולאחריה הרצאה מעמיקה ורב-שיח על פרנויה של המלחמה הקרה והאפקטים המיוחדים הפרקטיים של רוב בוטין מאת חוקר קולנוע הז׳אנר חגי יניב."
>
	<!-- Main Content Canvas -->
	<main dir="rtl" class="flex-grow w-full max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-8 flex flex-col gap-8 relative z-10 bg-surface">
		
		<!-- Hero Section & Event Overview -->
		<Hero />
				<!-- Lecturer Biography & Details -->
		<Lecturer />



		<!-- Screening & Lecture Schedule Log -->
		<Itinerary />

				<!-- Interactive Outpost 31 Retro Command Center & RSVP Station -->
		<CrtTerminal />



	</main>

	<!-- Global CRT Trailer Playback Feed Modal -->
	<TrailerModal />
</Layout>

