---

<section id="characters" class="relative">
  <div class="bg-surface-container border border-outline-variant p-6 md:p-8 relative hud-border shadow-lg">
    <div class="hud-corner-tl"></div>
    <div class="hud-corner-tr"></div>
    <div class="hud-corner-bl"></div>
    <div class="hud-corner-br"></div>
    
    <!-- Component Header -->
    <div class="border-b border-outline-variant/50 pb-2 mb-8 flex justify-between items-center">
      <h2 class="font-label-caps text-neon-blue tracking-widest text-sm flex items-center gap-2">
        <span class="material-symbols-outlined text-[16px] text-neon-blue">group</span>
        <span class="lang-he">תיקי מפתח: צוות אאוטפוסט 31</span>
        <span class="lang-en">KEY DOSSIERS: OUTPOST 31 STAFF</span>
      </h2>
      <span class="font-terminal-xs text-[10px] text-hazard-orange opacity-80 uppercase select-none">
        <span class="lang-he">// פרוטוקול בדיקת דם: פעיל</span>
        <span class="lang-en">// BLOOD TEST PROTOCOL: ACTIVE</span>
      </span>
    </div>

    <!-- Controls and Status Summary -->
    <div class="flex justify-between items-center mb-6 font-terminal-xs text-xs">
      <div class="flex items-center gap-3">
        <span class="w-2 h-2 bg-terminal-green rounded-full animate-ping"></span>
        <span class="text-on-surface-variant select-none">
          <span class="lang-he">נמצאו: 12 רשומות פעילות</span>
          <span class="lang-en">FOUND: 12 ACTIVE RECORDS</span>
        </span>
      </div>
      
      <!-- Arrow buttons for desktop/nav -->
      <div class="flex items-center gap-2 select-none">
        <button 
          id="carousel-prev" 
          class="border border-outline-variant hover:border-neon-blue hover:text-neon-blue bg-surface-container-low px-3 py-1.5 transition-all active:scale-95 cursor-pointer font-bold"
          aria-label="Previous character"
        >
          &lt;
        </button>
        <button 
          id="carousel-next" 
          class="border border-outline-variant hover:border-neon-blue hover:text-neon-blue bg-surface-container-low px-3 py-1.5 transition-all active:scale-95 cursor-pointer font-bold"
          aria-label="Next character"
        >
          &gt;
        </button>
      </div>
    </div>

    <!-- Carousel Container -->
    <div 
      id="characters-carousel" 
      class="embla overflow-hidden relative z-10"
    >
      <div class="embla__container flex gap-6 pb-6">
        {characters.map((char, index) => (
          <div class="embla__slide flex-shrink-0">
            <CharacterCard {...char} index={index} />
          </div>
        ))}
      </div>
    </div>

    <!-- Scroll Progress Indicator Bar -->
    <div class="mt-4 w-full h-1 bg-outline-variant/30 relative rounded overflow-hidden">
      <div 
        id="carousel-progress" 
        class="absolute left-0 top-0 h-full w-[0%] bg-neon-blue transition-all duration-75 relative rounded-full shadow-[0_0_8px_#2665fd]"
      ></div>
    </div>
  </div>
</section>

<style>
  .embla {
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
  .embla::-webkit-scrollbar {
    display: none; /* Chrome, Safari and Opera */
  }
  .embla__container {
    display: flex;
  }
  .embla__slide {
    flex: 0 0 auto;
    scroll-snap-align: start;
    min-width: 0;
  }
</style>

<script>
  const emblaNode = document.getElementById('characters-carousel');
  const prevBtn = document.getElementById('carousel-prev') as HTMLButtonElement;
  const nextBtn = document.getElementById('carousel-next') as HTMLButtonElement;
  const progressBar = document.getElementById('carousel-progress') as HTMLDivElement;

  if (emblaNode && prevBtn && nextBtn) {
    // Arrow button events
    const getScrollAmount = () => {
      const card = emblaNode.querySelector('.embla__slide');
      const cardWidth = card ? card.clientWidth : 300;
      const gap = 24; // gap-6 is 24px
      return cardWidth + gap;
    };

    prevBtn.addEventListener('click', () => {
      const isRtl = document.documentElement.dir === 'rtl';
      const scrollAmount = getScrollAmount();
      // In RTL, scrolling prev moves to the right (positive scrollLeft in modern browsers)
      const direction = isRtl ? 1 : -1;
      emblaNode.scrollBy({ left: direction * scrollAmount, behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', () => {
      const isRtl = document.documentElement.dir === 'rtl';
      const scrollAmount = getScrollAmount();
      // In RTL, scrolling next moves to the left (negative/decreasing scrollLeft in modern browsers)
      const direction = isRtl ? -1 : 1;
      emblaNode.scrollBy({ left: direction * scrollAmount, behavior: 'smooth' });
    });

    // Toggle arrow enabled states and progress bar on scroll
    const updateButtonsAndProgress = () => {
      const scrollLeft = Math.abs(emblaNode.scrollLeft);
      const maxScroll = emblaNode.scrollWidth - emblaNode.clientWidth;
      
      const canScrollPrev = scrollLeft > 10;
      const canScrollNext = scrollLeft < maxScroll - 10;
      
      prevBtn.disabled = !canScrollPrev;
      nextBtn.disabled = !canScrollNext;
      
      prevBtn.style.opacity = canScrollPrev ? '1' : '0.4';
      nextBtn.style.opacity = canScrollNext ? '1' : '0.4';
      
      prevBtn.style.cursor = canScrollPrev ? 'pointer' : 'not-allowed';
      nextBtn.style.cursor = canScrollNext ? 'pointer' : 'not-allowed';

      if (progressBar) {
        const progress = maxScroll > 0 ? Math.max(0, Math.min(1, scrollLeft / maxScroll)) : 1;
        progressBar.style.width = `${progress * 100}%`;
      }
    };

    // Highlight the active card in view dynamically
    const observerOptions = {
      root: emblaNode,
      threshold: 0.6, // Card is active if 60% of it is visible in the container
      rootMargin: '0px'
    };

    const cardObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // Remove active-card class from all cards
          emblaNode.querySelectorAll('.carousel-item').forEach(card => {
            card.classList.remove('active-card');
          });
          // Add active-card to the card inside this intersecting slide
          const cardEl = entry.target.querySelector('.carousel-item');
          if (cardEl) {
            cardEl.classList.add('active-card');
          }
        }
      });
    }, observerOptions);

    // Observe each slide wrapper
    emblaNode.querySelectorAll('.embla__slide').forEach(slide => {
      cardObserver.observe(slide);
    });

    // Also support manual clicks/taps on cards to snap and highlight them
    emblaNode.querySelectorAll('.embla__slide').forEach((slide) => {
      slide.addEventListener('click', (e) => {
        const card = slide.querySelector('.carousel-item');
        if (card) {
          // Remove active-card from all others, add to this one
          emblaNode.querySelectorAll('.carousel-item').forEach(c => c.classList.remove('active-card'));
          card.classList.add('active-card');
        }
        slide.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      });
    });

    emblaNode.addEventListener('scroll', updateButtonsAndProgress);

    // Initial run
    updateButtonsAndProgress();

    // Re-run on resize
    window.addEventListener('resize', updateButtonsAndProgress);

    // Re-run when language switches (dir changes)
    const observer = new MutationObserver(updateButtonsAndProgress);
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['dir'] });
  }
</script>
