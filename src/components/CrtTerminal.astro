      if (index === 0) lineDiv.classList.add('bright', 'font-bold');
      else if (index === 1 || index === 5) {
        lineDiv.className = 'prompt-line separator';
        if (index === 5) lineDiv.style.marginBottom = '12px';
      }
      else lineDiv.classList.add('dim');
      
      lineDiv.innerHTML = lineText;
      outputPane.insertBefore(lineDiv, liveLine);
    });

    if (commandInput) {
      commandInput.placeholder = localized.placeholder;
    }
    const execBtn = document.getElementById('exec-btn');
    if (execBtn) {
      execBtn.innerText = localized.exec;
    }
  }

  function addOutputLines(lines: string[]) {
    if (!outputPane || !liveLine) return;
    
    lines.forEach(lineText => {
      const lineDiv = document.createElement('div');
      lineDiv.className = 'prompt-line';
      
      // Basic highlight logic
      if (lineText.includes('CLEAR') || lineText.includes('OK') || lineText.includes('GRANTED') || lineText.includes('תקין') || lineText.includes('אושר')) {
        lineDiv.classList.add('success');
      } else if (lineText.includes('INFECTED') || lineText.includes('ASSIMILATION') || lineText.includes('WARNING') || lineText.includes('FAILURE') || lineText.includes('נגוע') || lineText.includes('אזהרה')) {
        lineDiv.classList.add('danger');
      } else if (lineText.includes('SUSPICIOUS') || lineText.includes('CONFINED') || lineText.includes('חשוד') || lineText.includes('בבידוד')) {
        lineDiv.classList.add('warn');
      }
      
      lineDiv.innerHTML = lineText;
      outputPane.insertBefore(lineDiv, liveLine);
    });
    
    // Auto-scroll
    outputPane.scrollTop = outputPane.scrollHeight;
  }

  function processCommand() {
    if (!commandInput || !liveLine || !outputPane) return;
    const fullVal = commandInput.value.trim();
    if (!fullVal) return;

    const activeLang = document.documentElement.lang || 'he';
    const langKey = activeLang === 'en' ? 'en' : 'he';

    // Play button execute beep
    audio.playBeep(650, 0.08);

    const parts = fullVal.split(' ');
    const cmd = parts[0].toUpperCase();
    const arg = parts.slice(1).join(' ');

    // Echo input onto terminal screen
    const echoDiv = document.createElement('div');
    echoDiv.className = 'prompt-line';
    echoDiv.innerHTML = `<span class="dim">A:\&gt;</span>&nbsp;${fullVal}`;
    outputPane.insertBefore(echoDiv, liveLine);

    if (cmd === 'CLEAR') {
      const allLines = outputPane.querySelectorAll('.prompt-line:not(#live-terminal-line)');
      allLines.forEach(l => l.remove());
    } else if (cmd === 'HELP') {
      addOutputLines(helpList_db[langKey]);
    } else if (cmd === 'COLOR') {
      const themeMsg = cycleColor();
      addOutputLines([themeMsg]);
    } else if (cmd === 'DIAGNOSTIC' || cmd === 'SYSTEM') {
      const resp = activeLang === 'en' ? [
        "PERFORMING FULL SUB-ICE UTILITY SCANS...",
        "GENERATOR CAPACITY : 84% [STABLE]",
        "STATION STRUCT TEMP: -44°C (EXTREME CHILL)",
        "OUTSIDE VENTILATION: BLOCKED BY COMPACT SNOW DRIFT",
        "COMS ARRAY STATUS  : DISCONNECTED. MCMURDO UNREACHABLE.",
        "THREAT METRIC      : HIGH CELLULAR THREAT DETECTED ON STATION PREMISES."
      ] : [
        "מבצע בדיקת מערכות תת-קרקעיות מקיפה...",
        "קיבולת גנרטור : 84% [יציב]",
        "טמפרטורת הבסיס: -44°C (קור קיצוני)",
        "אוורור חיצוני: חסום על ידי ערמות שלג גבוהות",
        "מצב תקשורת   : מנותק. בסיס מקמרדו אינו זמין.",
        "איום ביולוגי   : זוהה איום תאי גבוה בשטח הבסיס."
      ];
      addOutputLines(resp);
    } else if (cmd === 'ROSTER') {
      addOutputLines(rosters_db[langKey]);
    } else if (cmd === 'BLOODTEST') {
      if (!arg) {
        const err = activeLang === 'en' ? 
          ["ERROR: PROTOCOL REQUIRES ARGUMENT: 'BLOODTEST [SUBJECT]'", "EXAMPLE: 'BLOODTEST PALMER'"] : 
          ["שגיאה: הפרוטוקול דורש ארגומנט: 'BLOODTEST [שם SUBJECT]'", "דוגמה: 'BLOODTEST PALMER'"];
        addOutputLines(err);
      } else {
        const subject = arg.toUpperCase();
        const startScan = activeLang === 'en' ? 
          `INITIATING CELLULAR SCREENING SPECTRAL SCAN FOR SUBJECT: ${subject}` : 
          `מתחיל סריקה ספקטרלית ואנליזת תאים עבור: ${subject}`;
        addOutputLines([startScan]);
        audio.playSweep();
        
        setTimeout(() => {
          if (subject.includes('PALMER') || subject.includes('NORRIS')) {
            audio.playBeep(250, 0.4);
            const inf = activeLang === 'en' ? [
              "------------------------------------------------",
              `ALERT! BIO-SPECIMEN ANALYZER DETECTED INCONGRUENCY.`,
              `SUBJECT: ${subject}`,
              "ASSIMILATION PROBABILITY: [ 99.98% ]",
              "REACTION METRIC: MASSIVE FLAMMABLE ANOMALY DETECTED IN PETRI DISH.",
              "CLASSIFICATION: [ INFECTED ] — ENGAGE DEFENSIVE FLAMETHROWER TACTICS NOW.",
              "------------------------------------------------"
            ] : [
              "------------------------------------------------",
              `אזהרה! המנתח הביולוגי זיהה אי-התאמה תאית חמורה.`,
              `נבדק: ${subject}`,
              "הסתברות להדבקה: [ 99.98% ]",
              "תגובה לחום: זוהה עיוות תאי אלים ומדבק בצלחת הפטרי.",
              "סיווג: [ נגוע ] — הפעל להביור הגנתי באופן מיידי.",
              "------------------------------------------------"
            ];
            addOutputLines(inf);
          } else if (subject.includes('MACREADY') || subject.includes('CHILDS') || subject.includes('COPELAND')) {
            audio.playBeep(1100, 0.15);
            const clr = activeLang === 'en' ? [
              "------------------------------------------------",
              `SUBJECT: ${subject}`,
              "ASSIMILATION PROBABILITY: [ 0.04% ]",
              "REACTION METRIC: PURE CELLULAR ADHERENCE. NO REACTION TO SECURED COPPER WIRE HEAT TEST.",
              "CLASSIFICATION: [ CLEAR ]",
              "------------------------------------------------"
            ] : [
              "------------------------------------------------",
              `נבדק: ${subject}`,
              "הסתברות להדבקה: [ 0.04% ]",
              "תגובה לחום: היצמדות תאים תקינה. אין תגובה לבדיקת החום של חוט הנחושת.",
              "סיווג: [ נקי ]",
              "------------------------------------------------"
            ];
            addOutputLines(clr);
          } else {
            // Random output for custom entries
            const infected = Math.random() > 0.5;
            if (infected) {
              audio.playBeep(250, 0.4);
              const infRand = activeLang === 'en' ? [
                "------------------------------------------------",
                `SUBJECT: ${subject}`,
                "ASSIMILATION PROBABILITY: [ 87.4% ]",
                "REACTION METRIC: PARTIAL ASSIMILATION DETECTED.",
                "CLASSIFICATION: [ INFECTED ]",
                "------------------------------------------------"
              ] : [
                "------------------------------------------------",
                `נבדק: ${subject}`,
                "הסתברות להדבקה: [ 87.4% ]",
                "תגובה לחום: זוהתה הדבקה תאית חלקית.",
                "סיווג: [ נגוע ]",
                "------------------------------------------------"
              ];
              addOutputLines(infRand);
            } else {
              audio.playBeep(980, 0.12);
              const clrRand = activeLang === 'en' ? [
                "------------------------------------------------",
                `SUBJECT: ${subject}`,
                "ASSIMILATION PROBABILITY: [ 1.12% ]",
                "REACTION METRIC: CELLULAR INTEGRITY SATISFACTORY.",
                "CLASSIFICATION: [ CLEAR ]",
                "------------------------------------------------"
              ] : [
                "------------------------------------------------",
                `נבדק: ${subject}`,
                "הסתברות להדבקה: [ 1.12% ]",
                "תגובה לחום: יציבות תאים תקינה ומשביעת רצון.",
                "סיווג: [ נקי ]",
                "------------------------------------------------"
              ];
              addOutputLines(clrRand);
            }
          }
        }, 800);
      }
    } else if (cmd === 'LOGS') {
      addOutputLines(logs_index_db[langKey] || logs_index_db['he']);
    } else if (cmd === 'READ') {
      const fileLower = arg.toLowerCase();
      if (!arg) {
        const err = activeLang === 'en' ? 
          "ERROR: FILE IDENTIFIER BLANK. E.G., 'READ BLAIR.LOG'" : 
          "שגיאה: שם הקובץ ריק. דוגמה: 'READ BLAIR.LOG'";
        addOutputLines([err]);
      } else if (logs_db[langKey][fileLower]) {
        const startRead = activeLang === 'en' ? `DECRYPTING RESOURCE: ${arg.toUpperCase()}...` : `מפענח משאב נתונים: ${arg.toUpperCase()}...`;
        addOutputLines([startRead, ...logs_db[langKey][fileLower]]);
      } else {
        const notFound = activeLang === 'en' ? `FILE ERROR: NOT FOUND UNREADABLE: ${arg.toUpperCase()}` : `שגיאת קובץ: לא נמצא או אינו קריא: ${arg.toUpperCase()}`;
        addOutputLines([notFound]);
      }
    } else if (cmd === 'RSVP') {
      if (!arg) {
        const err = activeLang === 'en' ? 
          ["ERROR: ENTER YOUR NAME. PROTOCOL: 'RSVP [YOUR NAME]'", "EXAMPLE: 'RSVP R.J. MACREADY'"] : 
          ["שגיאה: נא להזין שם. פרוטוקול: 'RSVP [השם שלך]'", "דוגמה: 'RSVP R.J. MACREADY'"];
        addOutputLines(err);
      } else {
        const attendee = arg.toUpperCase();
        audio.playBeep(1200, 0.2);
        setTimeout(() => {
          audio.playBeep(1400, 0.2);
        }, 120);
        
        const badgeCode = 'OUTPOST31-' + Math.floor(100000 + Math.random() * 900000);
        const rsvpResp = activeLang === 'en' ? [
          "------------------------------------------------",
          "SYSTEM STATUS: ACCESS TICKET GRANTED",
          `HOLDER: ${attendee}`,
          `REGISTRY ID: ${badgeCode}`,
          "EVENT: THE THING SCREENING & SPECIALLY DECLASSIFIED LECTURE",
          "DATE: JUNE 11, 2026 @ 19:30 HOURS",
          "FACILITY CODE: OUTPOST 31 COMMUNION SHELTER",
          "------------------------------------------------"
        ] : [
          "------------------------------------------------",
          "מצב מערכת: כרטיס גישה אושר בהצלחה",
          `מחזיק: ${attendee}`,
          `מזהה רישום: ${badgeCode}`,
          "אירוע: הקרנה מיוחדת והרצאה חסויה של סרט THE THING",
          "תאריך: 11 ביוני, 2026 בשעה 19:30",
          "קוד מתקן: מקלט קהילתי אאוטפוסט 31",
          "------------------------------------------------"
        ];
        addOutputLines(rsvpResp);
      }
    } else if (cmd === 'WHATSAPP' || cmd === 'JOIN' || cmd === 'CHAT') {
      audio.playBeep(1200, 0.2);
      const waResp = activeLang === 'en' ? [
        "------------------------------------------------",
        "ESTABLISHING SECURE COM-LINK CHNL. WHATSAPP...",
        "STATUS: CONNECTED",
        "LINK: <a href='https://chat.whatsapp.com/IdrJQ24IP9vF2Owfvu3TGA?mode=gi_t' target='_blank' style='color:#22c55e;text-decoration:underline;'>CLICK HERE TO JOIN THE OUTPOST 31 GROUP</a>",
        "------------------------------------------------"
      ] : [
        "------------------------------------------------",
        "מקים ערוץ קשר מאובטח לחמ״ל בוואטסאפ...",
        "מצב: מחובר",
        "קישור: <a href='https://chat.whatsapp.com/IdrJQ24IP9vF2Owfvu3TGA?mode=gi_t' target='_blank' style='color:#22c55e;text-decoration:underline;'>לחצו כאן להצטרפות לקבוצה המאובטחת</a>",
        "------------------------------------------------"
      ];
      addOutputLines(waResp);
      setTimeout(() => {
        window.open('https://chat.whatsapp.com/IdrJQ24IP9vF2Owfvu3TGA?mode=gi_t', '_blank');
      }, 500);
    } else {
      const unsupported = activeLang === 'en' ? `COMMAND/PROTOCOL NOT SUPPORTED: '${cmd}'` : `הפקודה או הפרוטוקול אינם נתמכים: '${cmd}'`;
      addOutputLines([unsupported]);
    }

    commandInput.value = '';
    commandInput.focus();
  }

  const logs_index_db = {
    he: [
      "מערכת זיכרון פנימית מאובטחת של הבסיס:",
      "------------------------------------------------",
      "  BLAIR.LOG     - הערות מחקר על האנומליה התאית (1982-11-12)",
      "  MALKI.LOG     - יומן מטאורולוגי ונתוני תקשורת (1982-11-14)",
      "------------------------------------------------",
      "השתמש ב-'READ [LOGNAME]' כדי לקרוא קובץ מסוים."
    ],
    en: [
      "CLASSIFIED INTERNAL STATION MEMORY SYSTEM SECURE:",
      "------------------------------------------------",
      "  BLAIR.LOG     - CELLULAR ANOMALY STUDY NOTES (1982-11-12)",
      "  MALKI.LOG     - METEOROLOGICAL & COMS BLACKOUT LOG (1982-11-14)",
      "------------------------------------------------",
      "USE 'READ [LOGNAME]' TO DECRYPT AN INDIVIDUAL FILE PACK."
    ]
  };

  // Initialize terminal
  initTerminalLines();

  // Listen for language changes globally
  window.addEventListener('lang-changed', () => {
    initTerminalLines();
  });

  // Key sound and listeners
  commandInput?.addEventListener('input', () => {
    audio.playKey();
  });

  commandInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      processCommand();
    }
  });

  execButton?.addEventListener('click', () => {
    processCommand();
  });
</script>
