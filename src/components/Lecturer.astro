---
---

<section id="lecturer" class="relative">
	<div class="bg-surface-container border border-outline-variant p-6 md:p-8 relative hud-border shadow-lg">
		<div class="hud-corner-tl"></div>
		<div class="hud-corner-tr"></div>
		<div class="hud-corner-bl"></div>
		<div class="hud-corner-br"></div>
		
		<div class="border-b border-outline-variant/50 pb-2 mb-8">
			<span class="font-label-caps text-neon-blue tracking-widest text-sm">GUEST LECTURER DETAILS</span>
		</div>
		
		<div class="flex flex-col md:flex-row gap-8 items-start relative z-10">
			<!-- Lecturer Portrait -->
			<div class="w-40 h-40 shrink-0 border border-outline-variant p-1 bg-surface relative contrast-125 select-none shadow-md">
				<img 
					alt="Dr. Alexander T. Morgan - John Carpenter and Genre Cinema Scholar" 
					class="w-full h-full object-cover block brightness-125" 
					src="/images/lecturer.png"
				/>
			</div>
			
			<!-- Biography -->
			<div class="flex flex-col flex-grow w-full">
				<h3 class="font-label-caps text-3xl text-secondary mb-1">DR. ALEXANDER T. MORGAN</h3>
				<p class="font-terminal-xs text-sm text-hazard-orange mb-4 tracking-wider">Film Historian • Author • Genre Cinema Scholar</p>
				
				<p class="font-body-sm text-on-surface-variant text-base leading-relaxed mb-6 max-w-3xl">
					Dr. Morgan is a prominent film historian and genre cinema scholar specializing in 1980s practical effects, gothic horror tropes, and the works of John Carpenter. He is the author of the critically acclaimed monograph <em class="text-white">Inside the Shadows: The Cinema of John Carpenter</em> and has lectured internationally on the subtext of Cold War paranoia in science fiction cinema.
				</p>
				
				<button 
					id="toggle-lecturer-details-btn"
					class="self-start font-terminal-xs text-xs text-neon-blue hover:text-white border border-neon-blue/40 px-4 py-2 bg-neon-blue/5 hover:bg-neon-blue/20 transition-all duration-300 flex items-center gap-2 uppercase tracking-widest cursor-pointer focus:outline-none"
				>
					<span id="btn-text">LEARN MORE ABOUT DR. MORGAN</span>
					<span id="btn-icon" class="material-symbols-outlined text-[16px] transition-transform duration-300">arrow_forward</span>
				</button>
			</div>
		</div>

		<!-- Interactive Expanded Detail Drawer -->
		<div 
			id="lecturer-details-drawer" 
			class="hidden overflow-hidden transition-all duration-500 max-h-0 border-t border-outline-variant/30 mt-8 pt-6 relative z-10"
		>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-8 font-terminal-xs text-sm bg-black/40 border border-outline-variant/30 p-4 relative glow-border">
				<div class="flex flex-col gap-3">
					<span class="text-neon-blue font-bold uppercase tracking-wider">// ACADEMIC BIBLIOGRAPHY</span>
					<ul class="list-disc pl-4 space-y-2 text-on-surface-variant text-xs">
						<li>
							<strong class="text-white">Inside the Shadows: The Cinema of John Carpenter</strong> (Aero Press, 2018) — An extensive look into Carpenter's visuals and philosophies.
						</li>
						<li>
							<strong class="text-white">Practical Flesh & Blood</strong> (Macabre Press, 2021) — A historical analysis of practical horror visual effects from Rob Bottin to Stan Winston.
						</li>
						<li>
							<strong class="text-white">Fearing the Neighbor: Paranoia in 80s Horror</strong> (Journal of Film Studies, 2015) — Critical essay exploring the psychological dimensions of McCarthyism in sci-fi.
						</li>
					</ul>
				</div>
				<div class="flex flex-col gap-3">
					<span class="text-neon-blue font-bold uppercase tracking-wider">// LECTURE TOPICS COVERED</span>
					<ul class="list-disc pl-4 space-y-2 text-on-surface-variant text-xs">
						<li>
							<strong class="text-white">The Mutation of Rob Bottin:</strong> A technical outline of the practical animatronics, slime compounds, and rubber effects designed for *The Thing*.
						</li>
						<li>
							<strong class="text-white">Sub-zero Paranoia:</strong> Exploring isolation as a narrative driver and the breakdown of scientific rationality at Outpost 31.
						</li>
						<li>
							<strong class="text-white">Who Goes There?</strong> Tracing the evolution from John W. Campbell's original 1938 novella to Carpenter's masterpiece.
						</li>
					</ul>
				</div>
			</div>
		</div>

		<!-- Background seal watermark -->
		<div class="absolute right-8 bottom-8 opacity-5 pointer-events-none hidden md:block select-none">
			<div class="w-40 h-40 rounded-full border-2 border-white flex items-center justify-center border-dashed">
				<div class="text-center">
					<span class="font-label-caps text-[10px] block font-bold">U.S. ANTARCTICA</span>
					<span class="font-label-caps text-[10px] block">RESEARCH PROGRAM</span>
					<span class="material-symbols-outlined text-5xl my-2">ac_unit</span>
					<span class="font-label-caps text-[10px] block">EST. 1982</span>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	const toggleBtn = document.getElementById("toggle-lecturer-details-btn");
	const drawer = document.getElementById("lecturer-details-drawer");
	const btnText = document.getElementById("btn-text");
	const btnIcon = document.getElementById("btn-icon");

	if (toggleBtn && drawer && btnText && btnIcon) {
		toggleBtn.addEventListener("click", () => {
			const isCollapsed = drawer.classList.contains("hidden");
			
			if (isCollapsed) {
				// Expand
				drawer.classList.remove("hidden");
				drawer.style.maxHeight = "none";
				const fullHeight = drawer.scrollHeight + "px";
				drawer.style.maxHeight = "0px";
				
				// Force layout trigger
				drawer.offsetHeight; 
				
				drawer.style.maxHeight = fullHeight;
				btnText.innerText = "COLLAPSE DETAILS";
				btnIcon.style.transform = "rotate(90deg)";
				
				setTimeout(() => {
					drawer.classList.add("expanded");
				}, 500);
			} else {
				// Collapse
				drawer.style.maxHeight = drawer.scrollHeight + "px";
				drawer.offsetHeight; // trigger repaint
				
				drawer.style.maxHeight = "0px";
				btnText.innerText = "LEARN MORE ABOUT DR. MORGAN";
				btnIcon.style.transform = "rotate(0deg)";
				
				setTimeout(() => {
					drawer.classList.add("hidden");
					drawer.classList.remove("expanded");
				}, 500);
			}
		});
	}
</script>
