---
import { Image } from "astro:assets";
import lecturerImg from "../assets/lecturer.png";
import companyImg from "../assets/company.png";
---

<section id="lecturer" class="relative">
	<div class="bg-surface-container border border-outline-variant p-6 md:p-8 relative hud-border shadow-lg">
		<div class="hud-corner-tl"></div>
		<div class="hud-corner-tr"></div>
		<div class="hud-corner-bl"></div>
		<div class="hud-corner-br"></div>
		
		<div class="border-b border-outline-variant/50 pb-2 mb-8">
			<span class="font-label-caps text-neon-blue tracking-widest text-sm">פרטי המרצה האורח</span>
		</div>
		
		<div class="flex flex-col md:flex-row gap-8 items-start relative z-10">
			<div class="w-40 h-40 shrink-0 border border-outline-variant p-1 bg-surface relative contrast-125 select-none shadow-md">
				<Image 
					src={lecturerImg}
					alt="חגי יניב - חוקר ג׳ון קרפנטר וקולנוע ז׳אנר" 
					width={160}
					height={160}
					format="png"
					quality={80}
					class="w-full h-full object-cover block brightness-125" 
				/>
			</div>
			
			<!-- Biography -->
			<div class="flex flex-col flex-grow w-full">
				<h3 class="font-label-caps text-3xl text-secondary mb-1">חגי יניב</h3>
				<p class="font-terminal-xs text-sm text-hazard-orange mb-4 tracking-wider">אנליסט נתונים • קצין רישום ותיעוד • אחראי בידור </p>
				
				<div class="font-body-sm text-on-surface-variant text-base leading-relaxed mb-6 max-w-3xl flex flex-col gap-4">
					<p>
						התפקיד הרשמי שלי בכוח המשימה האמריקאי לחקר הקוטב הדרומי הוא לנהל את כל זרם הנתונים המטאורולוגיים, הלוגיסטיים והביולוגיים של התחנה, ולתעד בזמן אמת את פעילות הצוות. בפועל, החורף האנטארקטי קשוח, ופשוט סגרתי שמונה שבועות רצופים של מעבר על ארכיונים קולנועיים כדי לא להשתגע. אני הגיק של התחנה.
					</p>
					<p>
						בעוד שהמדענים האחרים מנסים להבין דגימות קרח, אני מתמחה במיפוי וניתוח של סצינות ואירועים שלפעמים עוברים בלי תשומת לב מיוחדת. בעברי ניהלתי את &laquo;מועדון הסרט הגרוע&raquo; של משלחות הקוטב (שם ניתחתי מקרי קצה קשים כמו <em class="text-white">The Room</em>, <em class="text-white">Manos: The Hands of Fate</em> וקטלוגים ישנים של <em class="text-white">Canon Films</em>).
					</p>
					<p>
						בנוסף, העברתי לצוות שתי הרצאות עומק אסטרטגיות על תנאי הישרדות במזג האוויר קיצוני לכיוון השני בכוכב הלכת <em class="text-white">Arakis</em> (AKA <em class="text-white">Dune</em>). זוהי המשימה המבצעית (וההרצאה) השמינית שלי.
					</p>
				</div>
			</div>
		</div>

		<!-- Background seal watermark -->
		<div class="absolute left-8 top-1/2 -translate-y-1/2 opacity-[0.06] pointer-events-none hidden md:block select-none w-44 h-44">
			<Image
				src={companyImg}
				alt=""
				width={176}
				height={176}
				format="png"
				quality={60}
				aria-hidden="true"
				class="w-full h-full object-contain"
			/>
		</div>
	</div>
</section>
