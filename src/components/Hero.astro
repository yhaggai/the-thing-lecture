---
import Countdown from "./Countdown.astro";
import { Image } from "astro:assets";
import bgImg from "../assets/background.png";
---

<section id="home" class="grid grid-cols-1 lg:grid-cols-12 gap-gutter min-h-[600px] relative">
	<!-- Hero Background Image (Spans Full Width behind content) -->
	<div class="absolute inset-0 border border-outline-variant/30 glow-border rounded overflow-hidden" style="z-index: -2;">
		<Image 
			src={bgImg}
			alt="Outpost 31 snowy arctic blizzard cinematic backdrop" 
			class="w-full h-full object-cover opacity-60 crt-flicker mix-blend-screen" 
			loading="eager"
			fetchpriority="high"
		/>
		<!-- Overlay gradient for text readability -->
		<div class="absolute inset-0 bg-gradient-to-r from-surface via-surface/85 to-transparent"></div>
		<div class="absolute inset-0 bg-gradient-to-t from-surface via-transparent to-transparent"></div>
	</div>
	<!-- Blizzard Snowstorm Background Layer (smaller particles, low z-index) -->
	<canvas id="snowCanvasBg" style="position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:-1;"></canvas>
	<!-- Blizzard Snowstorm Foreground Layer (bigger particles, high z-index) -->
	<canvas id="snowCanvasFg" style="position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9999;"></canvas>

	<!-- Left Content: Title & Info -->
	<div class="lg:col-span-7 z-10 flex flex-col justify-center p-6 md:p-8">
		<p class="font-label-caps text-label-caps text-hazard-orange mb-3 tracking-widest text-xs">הקרנת על מסך ענק והרצאת עומק</p>
		<h2 class="font-headline-lg text-lg text-secondary tracking-[0.2em] mb-1 uppercase">של ג׳ון קרפנטר</h2>
		<h1 class="font-distressed text-[72px] leading-[72px] md:text-[110px] md:leading-[100px] text-on-surface mb-6 drop-shadow-[0_0_20px_rgba(38,101,253,0.3)] transform -skew-x-6 select-none select-none">
			THE<br>THING
		</h1>
		<div class="flex items-center gap-4 mb-8">
			<div class="border border-neon-blue px-4 py-1 flex items-center gap-2 bg-surface/50 backdrop-blur-sm hud-border">
				<span class="font-label-caps text-sm text-neon-blue tracking-wider font-bold">1982</span>
				<div class="flex gap-1">
					<div class="w-1.5 h-3 bg-neon-blue transform skew-x-12"></div>
					<div class="w-1.5 h-3 bg-neon-blue transform skew-x-12 opacity-80"></div>
					<div class="w-1.5 h-3 bg-neon-blue transform skew-x-12 opacity-60"></div>
				</div>
			</div>
			<div class="font-terminal-xs text-[10px] text-neon-blue tracking-widest bg-ghost-blue px-3 py-1">
				עותק ארכיוני 35 מ״מ
			</div>
		</div>

		<div class="max-w-md space-y-4 mb-8">
			<p class="font-terminal-xs text-xs text-on-surface-variant border-r-2 border-neon-blue pr-4 pl-0 py-0.5 italic">
				״האדם הוא המקום החם ביותר להתחבא בו.״
			</p>
			<div class="bg-surface-container/80 backdrop-blur-md border border-outline-variant p-4 relative hud-border">
				<p class="font-body-sm text-sm text-on-surface-variant leading-relaxed m-0">
					הצטרפו אלינו להקרנת ארכיון מיוחדת של יצירת המופת במדע בדיוני ואימה משנת 1982 של ג׳ון קרפנטר <strong class="text-white font-medium">The Thing</strong>, ולאחריה דיון טכני מפורט על אפקטים מיוחדים פרקטיים, בידוד של תקופת המלחמה הקרה ואימה קוסמית.
				</p>
			</div>
		</div>

		<!-- Logistics Grid -->
		<div class="bg-surface-container/80 backdrop-blur-md border border-outline-variant p-4 relative hud-border w-full max-w-[509px]">
			<div class="hud-corner-tl"></div>
			<div class="hud-corner-tr"></div>
			<div class="hud-corner-bl"></div>
			<div class="hud-corner-br"></div>
			<div class="grid grid-cols-2 md:grid-cols-3 gap-6">
				<div class="flex items-start gap-3">
					<span class="material-symbols-outlined text-neon-blue">calendar_today</span>
					<div class="flex flex-col">
						<span class="font-terminal-xs text-[10px] text-on-surface-variant uppercase tracking-wider">תאריך</span>
						<span class="font-label-caps text-xs text-hazard-orange tracking-widest font-semibold mt-0.5">יום חמישי, 11 ביוני, 2026</span>
					</div>
				</div>
				<div class="flex items-start gap-3">
					<span class="material-symbols-outlined text-neon-blue">schedule</span>
					<div class="flex flex-col">
						<span class="font-terminal-xs text-[10px] text-on-surface-variant uppercase tracking-wider">שעה</span>
						<span class="font-label-caps text-xs text-hazard-orange tracking-widest font-semibold mt-0.5">19:30</span>
					</div>
				</div>
				<div class="flex items-start gap-3 col-span-2 md:col-span-1">
					<span class="material-symbols-outlined text-neon-blue">location_on</span>
					<div class="flex flex-col">
						<span class="font-terminal-xs text-[10px] text-on-surface-variant uppercase tracking-wider">תחנה</span>
						<span class="font-label-caps text-xs text-hazard-orange tracking-widest font-semibold mt-0.5">איזור המרכז</span>
					</div>
				</div>
			</div>
		</div>

		<!-- WhatsApp CTA Button -->
		<div class="mt-6 w-full">
			<a 
				href="https://chat.whatsapp.com/IdrJQ24IP9vF2Owfvu3TGA?mode=gi_t" 
				target="_blank" 
				rel="noopener noreferrer"
				class="group flex items-center justify-between border border-terminal-green/30 bg-surface-container/60 hover:bg-terminal-green/10 hover:border-terminal-green/80 transition-all duration-300 p-4 rounded relative hud-border overflow-hidden cursor-pointer"
				style="border-color: rgba(34, 197, 150, 0.3);"
			>
				<!-- Custom green hud corners -->
				<div class="absolute top-0 right-0 w-2 h-2 border-t border-r border-terminal-green"></div>
				<div class="absolute bottom-0 left-0 w-2 h-2 border-b border-l border-terminal-green"></div>
				
				<div class="flex items-center gap-4">
					<div class="w-10 h-10 rounded-full bg-terminal-green/20 flex items-center justify-center border border-terminal-green/40 group-hover:scale-110 transition-transform duration-300 relative">
						<span class="w-2.5 h-2.5 bg-terminal-green rounded-full absolute -top-0.5 -right-0.5 animate-pulse shadow-[0_0_8px_#22c55e]"></span>
						<!-- SVG WhatsApp Icon inside retro style or chat icon -->
						<svg class="w-5 h-5 text-terminal-green fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.513 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.66.986 3.284 1.489 4.836 1.49 5.375 0 9.75-4.332 9.752-9.658.001-2.58-1.01-5.005-2.848-6.844S14.075 1.245 11.5 1.245C6.12 1.245 1.748 5.578 1.746 10.905c0 1.602.493 3.167 1.427 4.542l-.993 3.63 3.877-.978zm11.233-5.32c-.105-.175-.385-.262-.77-.455-.385-.193-2.28-1.125-2.63-1.253-.35-.128-.606-.193-.86.193-.255.385-.98 1.253-1.2 1.477-.22.225-.44.248-.825.055-.385-.192-1.625-.6-3.096-1.91-1.144-1.02-1.916-2.28-2.14-2.666-.225-.385-.024-.593.168-.785.174-.173.385-.45.58-.675.19-.225.255-.385.385-.643.13-.257.065-.482-.033-.675-.1-.193-.86-2.074-1.18-2.842-.312-.75-.63-.647-.86-.66-.222-.012-.477-.015-.732-.015-.255 0-.67.096-1.02.482-.35.385-1.336 1.306-1.336 3.183s1.365 3.69 1.558 3.946c.193.257 2.687 4.103 6.51 5.753.91.393 1.62.628 2.172.803.914.29 1.746.248 2.404.15.733-.11 2.28-.93 2.6-1.83.32-.9 0-1.67-.103-1.83z"/>
						</svg>
					</div>
					<div class="flex flex-col text-right">
						<span class="font-label-caps text-[10px] text-terminal-green uppercase tracking-wider font-bold">ערוץ תקשורת פעיל</span>
						<span class="font-headline-lg text-sm text-on-surface tracking-wide mt-0.5">הצטרפו לקבוצת הוואטסאפ הרשמית של האירוע</span>
					</div>
				</div>
				
				<div class="flex items-center gap-1.5 pl-2" dir="ltr">
					<span class="font-terminal-xs text-xs text-terminal-green tracking-widest hidden sm:inline">JOIN GROUP</span>
					<span class="material-symbols-outlined text-terminal-green text-sm transform group-hover:translate-x-[-4px] transition-transform">chevron_left</span>
				</div>
			</a>
		</div>
	</div>


	<!-- Right Content: Widgets -->
	<div class="lg:col-span-5 z-10 flex flex-col justify-between gap-6 p-6 h-full min-h-[500px]">
		<!-- Countdown Widget -->
		<Countdown />

		<!-- Video Thumbnail / Feed -->
		<div class="bg-surface-container/95 border border-outline-variant p-1.5 relative group mt-auto shadow-lg" dir="ltr">
			<!-- Faux Tape Label -->
			<div class="absolute -top-3.5 left-1/2 transform -translate-x-1/2 bg-[#d2c9b5] text-surface px-4 py-0.5 z-20 border border-black/25 shadow-md rotate-1 flex items-center gap-2">
				<div class="w-1.5 h-1.5 bg-red-600 rounded-full animate-ping"></div>
				<span class="font-[Courier] text-xs font-black uppercase tracking-widest text-black/90">CHECK CHNL. 31</span>
			</div>
			
			<div class="relative overflow-hidden border border-black h-[200px] bg-black crt-screen">
				<div class="absolute inset-0 overflow-hidden transition-transform duration-700 group-hover:scale-[1.02]">
					<div class="crt-lowres-feed">
					<video
						id="hero-video"
						class="crt-surveillance-feed"
						src="/base-snow-loop-opt.mp4"
						autoplay
						muted
						loop
						playsinline
						aria-label="Outpost 31 Security Feed surveillance feed"
					></video>
					</div>
				</div>
				<div class="absolute inset-0 crt-phosphor pointer-events-none crt-flicker"></div>
				<div class="absolute inset-0 scanline opacity-50 pointer-events-none"></div>
				<div class="absolute inset-0 crt-vignette pointer-events-none"></div>
				<div class="absolute inset-0 crt-rgb-shift pointer-events-none"></div>
				<div class="absolute inset-0 crt-vhs-noise pointer-events-none"></div>
				
				<!-- Overlay UI indicators -->
				<div class="absolute bottom-2 left-3 right-3 flex justify-between items-center text-white/80 border-b border-white/20 pb-1 font-terminal-xs text-[9px] tracking-widest select-none pointer-events-none">
					<span>/// SECURE BROADCAST</span>
					<span>PLAY [SP]</span>
				</div>
				<div class="absolute top-2 left-3 text-white/80 font-terminal-xs text-[9px] tracking-widest select-none pointer-events-none flex items-center gap-1">
					<div class="w-1.5 h-1.5 rounded-full bg-red-600 animate-pulse"></div>
					<span>REC CAM_04</span>
				</div>
				
				<!-- Play button -->
				<button 
					id="hero-play-btn"
					aria-label="Play security transmission trailer"
					class="hidden absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 text-white/40 hover:text-neon-blue text-5xl hover:scale-110 active:scale-95 transition-all duration-300 drop-shadow-[0_0_15px_rgba(0,0,0,0.8)] cursor-pointer focus:outline-none"
				>
					<span class="material-symbols-outlined text-5xl" style="font-variation-settings: 'FILL' 1;">play_circle</span>
				</button>
			</div>

			<!-- Hazard Warning Bar -->
			<div class="mt-1.5 flex h-6 border border-outline-variant bg-surface select-none">
				<div class="flex items-center justify-center px-2 border-r border-outline-variant text-hazard-orange">
					<span class="material-symbols-outlined text-[14px]">science</span>
				</div>
				<div class="flex-grow flex items-center min-w-0 bg-hazard-orange/10 overflow-hidden">
					<span class="font-terminal-xs text-[9px] text-hazard-orange pl-2 pr-1 font-bold shrink-0 z-10 bg-hazard-orange/10">WARNING:</span>
					<div class="flex-1 min-w-0 overflow-hidden">
						<span class="font-terminal-xs text-[9px] text-on-surface-variant tracking-wider uppercase whitespace-nowrap inline-block animate-[marquee_15s_linear_infinite]">
							INFECTION LEVEL UNRESOLVED --- LOCKDOWN LEVEL-03 ENGAGED --- AVOID DIRECT CONTACT
						</span>
					</div>
				</div>
				<div class="w-16 bg-hazard-stripes shrink-0"></div>
			</div>
		</div>
	</div>
</section>

<script>
	const playBtn = document.getElementById("hero-play-btn");
	if (playBtn) {
		playBtn.addEventListener("click", () => {
			// Dispatch event to show the TrailerModal
			window.dispatchEvent(new CustomEvent("open-trailer"));
		});
	}


	// Blizzard Snowstorm Effect (2 layers: Background and Foreground)
	(function(){
		const canvasBg = document.getElementById('snowCanvasBg') as HTMLCanvasElement | null;
		const canvasFg = document.getElementById('snowCanvasFg') as HTMLCanvasElement | null;
		if (!canvasBg || !canvasFg) return;
		
		const ctxBg = canvasBg.getContext('2d');
		const ctxFg = canvasFg.getContext('2d');
		if (!ctxBg || !ctxFg) return;
		
		let currentWind = 8;
		let targetWind = 8;
		
		// Background (small, slow, subtle, dense)
		let activeCountBg = 350;
		const MAX_COUNT_BG = 600;
		
		// Foreground (large, fast, prominent, sparse)
		let activeCountFg = 100;
		const MAX_COUNT_FG = 250;

		interface Flake {
			x: number;
			y: number;
			r: number;
			speed: number;
			wobble: number;
			wobbleSpeed: number;
			opacity: number;
			layer: number;
		}
		
		let flakesBg: Flake[] = [];
		let flakesFg: Flake[] = [];
		
		function resize(){ 
			if (canvasBg && canvasFg) {
				canvasBg.width = window.innerWidth; 
				canvasBg.height = window.innerHeight; 
				canvasFg.width = window.innerWidth; 
				canvasFg.height = window.innerHeight; 
			}
		}
		resize(); 
		window.addEventListener('resize', resize);
		
		function rndBg(): Flake { 
			return { 
				x: Math.random() * (canvasBg?.width || window.innerWidth), 
				y: Math.random() * (canvasBg?.height || window.innerHeight) - (canvasBg?.height || window.innerHeight), 
				r: Math.random() * 1.2 + 0.4, 
				speed: Math.random() * 1.5 + 0.6, 
				wobble: Math.random() * Math.PI * 2, 
				wobbleSpeed: (Math.random() - 0.5) * 0.03, 
				opacity: Math.random() * 0.5 + 0.2, 
				layer: Math.random() 
			}; 
		}
		
		function rndFg(): Flake { 
			return { 
				x: Math.random() * (canvasFg?.width || window.innerWidth), 
				y: Math.random() * (canvasFg?.height || window.innerHeight) - (canvasFg?.height || window.innerHeight), 
				r: Math.random() * 2.5 + 1.8, 
				speed: Math.random() * 3.0 + 1.8, 
				wobble: Math.random() * Math.PI * 2, 
				wobbleSpeed: (Math.random() - 0.5) * 0.05, 
				opacity: Math.random() * 0.5 + 0.4, 
				layer: Math.random() 
			}; 
		}
		
		// Initialize flakes
		for(let i=0; i<MAX_COUNT_BG; i++){ 
			const f = rndBg(); 
			f.y = Math.random() * (canvasBg?.height || window.innerHeight); 
			flakesBg.push(f); 
		}
		for(let i=0; i<MAX_COUNT_FG; i++){ 
			const f = rndFg(); 
			f.y = Math.random() * (canvasFg?.height || window.innerHeight); 
			flakesFg.push(f); 
		}

		// Randomize storm intensity values every 10 seconds
		setInterval(() => {
			targetWind = Math.random() * 20 - 8; // Range: -8 (heavy left gust) to 12 (heavy right gust)
			activeCountBg = Math.floor(Math.random() * 300 + 200); // 200 to 500 active particles
			activeCountFg = Math.floor(Math.random() * 100 + 60);  // 60 to 160 active particles
		}, 10000);

		function draw(){
			if (!canvasBg || !canvasFg || !ctxBg || !ctxFg) return;
			ctxBg.clearRect(0, 0, canvasBg.width, canvasBg.height);
			ctxFg.clearRect(0, 0, canvasFg.width, canvasFg.height);
			
			// Smoothly interpolate wind gusts
			currentWind += (targetWind - currentWind) * 0.02;

			// Draw Background Snow (low z-index)
			const activeBg = flakesBg.slice(0, activeCountBg);
			activeBg.forEach(f => {
				const d = 0.5 + f.layer * 0.5; 
				f.wobble += f.wobbleSpeed; 
				f.x += currentWind * d + Math.sin(f.wobble) * 0.8 * d; 
				f.y += f.speed * d + Math.abs(currentWind) * 0.15;
				if(f.y > canvasBg.height + 10){
					f.y = -10;
					f.x = Math.random() * canvasBg.width;
				}
				if(f.x > canvasBg.width + 20) f.x = -10; 
				if(f.x < -20) f.x = canvasBg.width + 10;
				const b = 210 + Math.floor(f.layer * 45);
				ctxBg.globalAlpha = f.opacity * d; 
				ctxBg.beginPath(); 
				ctxBg.arc(f.x, f.y, f.r * d, 0, Math.PI * 2); 
				ctxBg.fillStyle = `rgb(${b},${b},255)`; 
				ctxBg.fill(); 
				ctxBg.globalAlpha = 1;
			});

			// Draw Foreground Snow (high z-index)
			const activeFg = flakesFg.slice(0, activeCountFg);
			activeFg.forEach(f => {
				const d = 0.5 + f.layer * 0.5; 
				f.wobble += f.wobbleSpeed; 
				f.x += currentWind * d + Math.sin(f.wobble) * 0.8 * d; 
				f.y += f.speed * d + Math.abs(currentWind) * 0.22;
				if(f.y > canvasFg.height + 10){
					f.y = -10;
					f.x = Math.random() * canvasFg.width;
				}
				if(f.x > canvasFg.width + 20) f.x = -10; 
				if(f.x < -20) f.x = canvasFg.width + 10;
				const b = 230 + Math.floor(f.layer * 25);
				ctxFg.globalAlpha = f.opacity * d; 
				ctxFg.beginPath(); 
				ctxFg.arc(f.x, f.y, f.r * d, 0, Math.PI * 2); 
				ctxFg.fillStyle = `rgb(${b},${b},255)`; 
				ctxFg.fill(); 
				ctxFg.globalAlpha = 1;
			});

			requestAnimationFrame(draw);
		}
		draw();
	})();
</script>

<style>
	/* Custom marquee style for the hazard ticker */
	@keyframes marquee {
		0% { transform: translateX(100%); }
		100% { transform: translateX(-100%); }
	}
	.animate-\[marquee_15s_linear_infinite\] {
		animation: marquee 18s linear infinite;
	}
</style>
