---
---

<section id="the-film" class="relative">
	<div class="bg-surface-container border border-outline-variant p-6 md:p-8 relative hud-border shadow-lg">
		<div class="hud-corner-tl"></div>
		<div class="hud-corner-tr"></div>
		<div class="hud-corner-bl"></div>
		<div class="hud-corner-br"></div>
		
		<div class="border-b border-outline-variant/50 pb-2 mb-8 flex justify-between items-center">
			<span class="font-label-caps text-neon-blue tracking-widest text-sm">קובץ ארכיון: פרויקט The Thing (1982)</span>
			<span class="font-terminal-xs text-[10px] text-hazard-orange opacity-80 uppercase">// גישה ברמה 04 פעילה</span>
		</div>
		
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start relative z-10">
			<!-- Technical Specifications Card (col-span-4) -->
			<div class="lg:col-span-4 border border-outline-variant/40 bg-black/40 p-4 font-terminal-xs relative flex flex-col gap-4">
				<span class="text-neon-blue text-xs font-bold uppercase tracking-widest border-b border-outline-variant/30 pb-1.5 flex items-center gap-1.5">
					<span class="material-symbols-outlined text-[14px]">settings</span>
					גיליון רישום טכני
				</span>
				
				<div class="flex flex-col gap-3 text-xs">
					<div class="flex justify-between border-b border-outline-variant/20 pb-1">
						<span class="text-on-surface-variant">במאי:</span>
						<span class="text-white font-medium">ג׳ון קרפנטר</span>
					</div>
					<div class="flex justify-between border-b border-outline-variant/20 pb-1">
						<span class="text-on-surface-variant">מפיקים:</span>
						<span class="text-white font-medium">תורמן-פוסטר</span>
					</div>
					<div class="flex justify-between border-b border-outline-variant/20 pb-1">
						<span class="text-on-surface-variant">תסריטאי:</span>
						<span class="text-white font-medium">ביל לנקסטר</span>
					</div>
					<div class="flex justify-between border-b border-outline-variant/20 pb-1">
						<span class="text-on-surface-variant">מלחין:</span>
						<span class="text-white font-medium">אניו מוריקונה</span>
					</div>
					<div class="flex justify-between border-b border-outline-variant/20 pb-1">
						<span class="text-on-surface-variant">תאריך יציאה:</span>
						<span class="text-white font-medium">25 ביוני, 1982</span>
					</div>
					<div class="flex justify-between border-b border-outline-variant/20 pb-1">
						<span class="text-on-surface-variant">תקציב:</span>
						<span class="text-white font-medium">$15,000,000</span>
					</div>
					<div class="flex justify-between border-b border-outline-variant/20 pb-1">
						<span class="text-on-surface-variant">צוות אפקטים:</span>
						<span class="text-hazard-orange font-medium font-bold">רוב בוטין (בן 22)</span>
					</div>
				</div>

				<div class="bg-hazard-stripes-dark h-5 border border-outline-variant/40 mt-2 flex items-center justify-center">
					<span class="text-[9px] text-hazard-orange font-bold tracking-widest uppercase">בידוד קפדני פעיל</span>
				</div>
			</div>

			<!-- Practical Effects Dossier Tabs (col-span-8) -->
			<div class="lg:col-span-8 flex flex-col gap-4">
				<p class="font-body-sm text-sm text-on-surface-variant leading-relaxed">
					סרטו של ג׳ון קרפנטר *היצור* (The Thing) מוערך ברחבי העולם ככיתת אמן באפקטים חזותיים פרקטיים. בהובלתו של רוב בוטין בן ה-22 וצוות של 40 אמנים שעבדו 7 ימים בשבוע, הסרט דחה את חליפות המפלצת הסטנדרטיות לטובת גומי, פלדה, ריר ומערכות הידראוליות ליצירת אורגניזם שמשתנה ללא הרף.
				</p>
				
				<!-- Tabs Navigation -->
				<div class="flex flex-wrap border-b border-outline-variant/30 font-terminal-xs text-xs mt-2 select-none">
					<button 
						id="tab-kennel-btn"
						class="px-4 py-2 border-b-2 border-neon-blue text-neon-blue bg-neon-blue/5 hover:bg-neon-blue/10 transition-colors uppercase tracking-wider font-bold cursor-pointer"
					>
						[ קובץ 01: היצור במכונת הכלבים ]
					</button>
					<button 
						id="tab-norris-btn"
						class="px-4 py-2 border-b-2 border-transparent text-on-surface-variant hover:text-white transition-colors uppercase tracking-wider font-bold cursor-pointer"
					>
						[ קובץ 02: ראש-עכביש של נוריס ]
					</button>
					<button 
						id="tab-split-btn"
						class="px-4 py-2 border-b-2 border-transparent text-on-surface-variant hover:text-white transition-colors uppercase tracking-wider font-bold cursor-pointer"
					>
						[ קובץ 03: מוטאנט חצוי-פנים ]
					</button>
				</div>

				<!-- Tab Contents -->
				<div class="border border-outline-variant/30 bg-black/10 p-4 font-terminal-xs">
					
					<!-- Tab 1: Kennel Thing -->
					<div id="tab-kennel-content" class="flex flex-col gap-3">
						<div class="flex justify-between items-center text-xs text-hazard-orange">
							<span>תיעוד: מקרה_זיהום_01</span>
							<span>סיווג: עוין ביותר</span>
						</div>
						<h4 class="text-white font-bold text-sm uppercase">היצור במכונת הכלבים</h4>
						<p class="text-xs text-on-surface-variant leading-relaxed">
							החשיפה הפיזית המלאה הראשונה של האורגניזם החוצני בתוך מכלאת כלבי המזחלת. נבנה באמצעות שלדת שלד פלדה מורכבת, מפוחי פנאומטיים, שלפוחיות אוויר לסימולציה של בשר פועם, ריר אורתן ומעיים של חיות אמיתיות.
						</p>
						<div class="border-t border-outline-variant/20 pt-2 flex items-center justify-between text-[10px] text-on-surface-variant">
							<span>מכניקה: 12 מפעילים, הידראוליקה כפולה</span>
							<span>חומר: סיליקון, קצף פוליאוריטן</span>
						</div>
					</div>

					<!-- Tab 2: Norris Head-Spider (Hidden by default) -->
					<div id="tab-norris-content" class="hidden flex flex-col gap-3">
						<div class="flex justify-between items-center text-xs text-hazard-orange">
							<span>תיעוד: מקרה_זיהום_04</span>
							<span>סיווג: מוטציה של איברים</span>
						</div>
						<h4 class="text-white font-bold text-sm uppercase">ראש-עכביש ופה-חזה של נוריס</h4>
						<p class="text-xs text-on-surface-variant leading-relaxed">
							במהלך ניסיון החייאת חזה, כלוב החזה של נוריס נפתח ללוע עצום, קוטע את זרועותיו של ד״ר קופר, בעוד ראשו נקרע מעצמו, מגדל רגלי עכביש וזוחל משם. נבנה באמצעות תבניות פיברגלס, שיני אקריליק דנטליות, פלסטיק מותך ומערכות בובות המופעלות מתחת לרצפה כפולה.
						</p>
						<div class="border-t border-outline-variant/20 pt-2 flex items-center justify-between text-[10px] text-on-surface-variant">
							<span>מכניקה: מתקן עריפת ראש הפוך</span>
							<span>חומר: לטקס, אקריליק דנטלי, תיל פלדה</span>
						</div>
					</div>

					<!-- Tab 3: Split-Face Mutant (Hidden by default) -->
					<div id="tab-split-content" class="hidden flex flex-col gap-3">
						<div class="flex justify-between items-center text-xs text-hazard-orange">
							<span>תיעוד: מקרה_זיהום_02</span>
							<span>סיווג: היבריד תאי מאקרו</span>
						</div>
						<h4 class="text-white font-bold text-sm uppercase">מוטאנט חצוי-פנים (בנינגס/היצור)</h4>
						<p class="text-xs text-on-surface-variant leading-relaxed">
							ההיבריד הגרוטסקי, החצי-בלוע של בנינגס שהתגלה במכלאת הקרח. בוטין עיצב את מבנה ׳חצוי-הפנים׳ האייקוני באמצעות תבניות לטקס מוקצפות, תרכובות עור ג׳לטין וצינורות אוויר כדי להציג את הבשר נמתח ומשתנה באוויר הקר.
						</p>
						<div class="border-t border-outline-variant/20 pt-2 flex items-center justify-between text-[10px] text-on-surface-variant">
							<span>מכניקה: מעטפת מתרחבת תרמופלסטית</span>
							<span>חומר: ג׳לטין, לטקס מוקצף, סיליקון נוזלי</span>
						</div>
					</div>

				</div>
			</div>
		</div>
	</div>
</section>

<script>
	const tabs = [
		{ btnId: "tab-kennel-btn", contentId: "tab-kennel-content" },
		{ btnId: "tab-norris-btn", contentId: "tab-norris-content" },
		{ btnId: "tab-split-btn", contentId: "tab-split-content" }
	];

	tabs.forEach((tab, index) => {
		const btn = document.getElementById(tab.btnId);
		const content = document.getElementById(tab.contentId);

		if (btn && content) {
			btn.addEventListener("click", () => {
				// Hide all contents and remove active styling from all buttons
				tabs.forEach(t => {
					const b = document.getElementById(t.btnId);
					const c = document.getElementById(t.contentId);
					if (b && c) {
						c.classList.add("hidden");
						b.classList.remove("border-neon-blue", "text-neon-blue", "bg-neon-blue/5");
						b.classList.add("border-transparent", "text-on-surface-variant");
					}
				});

				// Show target content and add active styling
				content.classList.remove("hidden");
				btn.classList.remove("border-transparent", "text-on-surface-variant");
				btn.classList.add("border-neon-blue", "text-neon-blue", "bg-neon-blue/5");
			});
		}
	});
</script>
