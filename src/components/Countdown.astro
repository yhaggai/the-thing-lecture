---
import CountdownTimer from './CountdownTimer';
---

<div class="bg-surface-container/80 backdrop-blur-md border border-outline-variant p-4 relative hud-border w-full max-w-[509px]">
	<!-- Corners for HUD styling -->
	<div class="hud-corner-tl"></div>
	<div class="hud-corner-tr"></div>
	<div class="hud-corner-bl"></div>
	<div class="hud-corner-br"></div>

	<div class="flex justify-between items-center mb-4 border-b border-outline-variant/50 pb-2">
		<div class="flex items-center gap-2">
			<div class="w-1.5 h-1.5 bg-hazard-orange rounded-full animate-pulse"></div>
			<span class="font-terminal-xs text-xs text-neon-blue uppercase tracking-wider">
				<span class="lang-he">האירוע מתחיל בעוד</span>
				<span class="lang-en">EVENT COUNTDOWN</span>
			</span>
		</div>
		<div class="flex gap-1 opacity-50">
			<div class="w-1 h-3 bg-neon-blue transform skew-x-12"></div>
			<div class="w-1 h-3 bg-neon-blue transform skew-x-12"></div>
			<div class="w-1 h-3 bg-neon-blue transform skew-x-12"></div>
		</div>
	</div>

	<CountdownTimer client:load />
</div>
