---
---

<section id="itinerary" class="relative">
	<div class="bg-surface-container border border-outline-variant p-6 md:p-8 relative hud-border shadow-lg">
		<div class="hud-corner-tl"></div>
		<div class="hud-corner-tr"></div>
		<div class="hud-corner-bl"></div>
		<div class="hud-corner-br"></div>
		
		<div class="border-b border-outline-variant/50 pb-2 mb-8 flex justify-between items-center">
			<span class="font-label-caps text-neon-blue tracking-widest text-sm">STATION LOG: EVENT ITINERARY</span>
			<span class="font-terminal-xs text-[10px] text-on-surface-variant opacity-60 uppercase hidden sm:inline">WY-31 LOG ENTRY SECTOR</span>
		</div>
		
		<!-- Itinerary Timeline Grid -->
		<div class="flex flex-col gap-4 font-terminal-xs">
			
			<!-- Item 1 -->
			<div class="grid grid-cols-1 sm:grid-cols-12 gap-3 p-4 border border-outline-variant/30 bg-black/20 hover:bg-neon-blue/5 hover:border-neon-blue/40 transition-all duration-300 group">
				<div class="sm:col-span-2 flex items-center gap-2">
					<span class="material-symbols-outlined text-neon-blue text-sm group-hover:animate-pulse">login</span>
					<span class="text-secondary font-bold text-base">19:00</span>
				</div>
				<div class="sm:col-span-4 flex flex-col justify-center">
					<span class="text-white font-bold tracking-wide uppercase">BASE ACCESS OPENED</span>
					<span class="text-[10px] text-hazard-orange tracking-widest uppercase mt-0.5">SECURE CHECKPOINT-31</span>
				</div>
				<div class="sm:col-span-6 flex items-center">
					<p class="text-xs text-on-surface-variant leading-relaxed">
						Registration & check-in. Cold-weather shelter entry. Ambient Antarctic soundscapes and pre-screening visual static loop activated.
					</p>
				</div>
			</div>

			<!-- Item 2 -->
			<div class="grid grid-cols-1 sm:grid-cols-12 gap-3 p-4 border border-outline-variant/30 bg-black/20 hover:bg-neon-blue/5 hover:border-neon-blue/40 transition-all duration-300 group">
				<div class="sm:col-span-2 flex items-center gap-2">
					<span class="material-symbols-outlined text-neon-blue text-sm group-hover:animate-pulse">record_voice_over</span>
					<span class="text-secondary font-bold text-base">19:30</span>
				</div>
				<div class="sm:col-span-4 flex flex-col justify-center">
					<span class="text-white font-bold tracking-wide uppercase">LECTURE INTRODUCTION</span>
					<span class="text-[10px] text-neon-blue tracking-widest uppercase mt-0.5">DR. ALEXANDER MORGAN</span>
				</div>
				<div class="sm:col-span-6 flex items-center">
					<p class="text-xs text-on-surface-variant leading-relaxed">
						Opening remarks by Dr. Morgan. Historical context of 1982 genre cinema, practical special effects, and Rob Bottin's revolutionary techniques.
					</p>
				</div>
			</div>

			<!-- Item 3 -->
			<div class="grid grid-cols-1 sm:grid-cols-12 gap-3 p-4 border border-outline-variant/30 bg-black/20 hover:bg-neon-blue/5 hover:border-neon-blue/40 transition-all duration-300 group">
				<div class="sm:col-span-2 flex items-center gap-2">
					<span class="material-symbols-outlined text-neon-blue text-sm group-hover:animate-pulse">movie</span>
					<span class="text-secondary font-bold text-base">19:45</span>
				</div>
				<div class="sm:col-span-4 flex flex-col justify-center">
					<span class="text-white font-bold tracking-wide uppercase">THE THING SCREENING</span>
					<span class="text-[10px] text-hazard-orange tracking-widest uppercase mt-0.5">35MM ARCHIVAL PRINT</span>
				</div>
				<div class="sm:col-span-6 flex items-center">
					<p class="text-xs text-on-surface-variant leading-relaxed">
						Archival 35mm projection of John Carpenter's 1982 classic *The Thing* (109 min). Stereo audio feeds locked, all lights extinguished.
					</p>
				</div>
			</div>

			<!-- Item 4 -->
			<div class="grid grid-cols-1 sm:grid-cols-12 gap-3 p-4 border border-outline-variant/30 bg-black/20 hover:bg-neon-blue/5 hover:border-neon-blue/40 transition-all duration-300 group">
				<div class="sm:col-span-2 flex items-center gap-2">
					<span class="material-symbols-outlined text-neon-blue text-sm group-hover:animate-pulse">forum</span>
					<span class="text-secondary font-bold text-base">21:35</span>
				</div>
				<div class="sm:col-span-4 flex flex-col justify-center">
					<span class="text-white font-bold tracking-wide uppercase">TECHNICAL LECTURE & Q&A</span>
					<span class="text-[10px] text-neon-blue tracking-widest uppercase mt-0.5">PRACTICAL SHADOWS</span>
				</div>
				<div class="sm:col-span-6 flex items-center">
					<p class="text-xs text-on-surface-variant leading-relaxed">
						Dr. Morgan leads an interactive lecture on Cold War isolation, paranoia tropes, practical mutations, and opens the floor for audience Q&A.
					</p>
				</div>
			</div>

			<!-- Item 5 -->
			<div class="grid grid-cols-1 sm:grid-cols-12 gap-3 p-4 border border-outline-variant/30 bg-black/20 hover:bg-neon-blue/5 hover:border-neon-blue/40 transition-all duration-300 group">
				<div class="sm:col-span-2 flex items-center gap-2">
					<span class="material-symbols-outlined text-neon-blue text-sm group-hover:animate-pulse">logout</span>
					<span class="text-secondary font-bold text-base">22:30</span>
				</div>
				<div class="sm:col-span-4 flex flex-col justify-center">
					<span class="text-white font-bold tracking-wide uppercase">OUTPOST DECOMPRESSION</span>
					<span class="text-[10px] text-hazard-orange tracking-widest uppercase mt-0.5">BAR SOCIAL MIXER</span>
				</div>
				<div class="sm:col-span-6 flex items-center">
					<p class="text-xs text-on-surface-variant leading-relaxed">
						Post-screening reception. Station-themed dry drinks and synthetic beer served. Decontamination checklist finalized.
					</p>
				</div>
			</div>

		</div>
	</div>
</section>
