---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "OUTPOST 31 FILM SERIES - THE THING", 
	description = "Join us for a special 35mm screening of John Carpenter's 1982 sci-fi horror classic 'The Thing' followed by an in-depth lecture and discussion." 
} = Astro.props;
---

<!DOCTYPE html>
<html class="dark" lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- Open Graph Meta Tags -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:image" content="/images/hero.jpg" />

		<!-- Material Symbols -->
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
		
		<!-- gl-matrix for WebGL globe animation -->
		<script src="https://cdnjs.cloudflare.com/ajax/libs/gl-matrix/2.8.1/gl-matrix-min.js" is:inline></script>

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;700&family=Space+Grotesk:wght@600;700&family=Creepster&display=swap" rel="stylesheet" />
	</head>
	<body class="bg-surface text-on-surface min-h-screen flex flex-col font-body-md overflow-x-hidden selection:bg-neon-blue selection:text-white">
		<!-- Ambient Scanline Overlay for CRT vibe -->
		<div class="fixed inset-0 pointer-events-none z-[100] scanline opacity-25"></div>

		<!-- Top Navigation (Shared Component) - Desktop Only -->
		<nav dir="ltr" class="hidden md:flex w-screen bg-surface-container-lowest border-b border-outline-variant bg-opacity-90 backdrop-blur-md sticky top-0 z-50">
			<div class="flex justify-between items-center w-full max-w-container-max mx-auto px-margin-desktop py-4">
			<div class="flex items-center gap-4">
				<div class="w-8 h-8 border border-neon-blue rounded-full flex items-center justify-center relative glow-border overflow-hidden">
					<canvas id="gc" class="w-full h-full block" width="64" height="64"></canvas>
					<!-- Crosshair overlay -->
					<div class="absolute inset-0 border-[0.5px] border-neon-blue/30 rounded-full pointer-events-none"></div>
				</div>
				<div class="flex flex-col">
					<span class="font-headline-lg text-lg uppercase tracking-widest text-on-surface leading-tight">OUTPOST 31</span>
					<span class="font-label-caps text-[9px] text-hazard-orange tracking-widest leading-none">FILM SERIES</span>
				</div>
			</div>

			<div class="flex items-center gap-4 border border-outline-variant p-2 bg-surface-container-low hud-border">
				<div class="w-12 h-8 bg-black border border-neon-blue/30 relative overflow-hidden flex items-center justify-center">
					<video
						class="absolute inset-0 w-full h-full object-cover"
						src="/signal-opt.mp4"
						autoplay
						muted
						loop
						playsinline
					></video>
				</div>
				<div class="flex flex-col">
					<span class="font-terminal-xs text-[8px] text-neon-blue">U.S. ANTARCTICA</span>
					<span class="font-terminal-xs text-[8px] text-neon-blue">RESEARCH STATION 31</span>
				</div>
				<div class="flex items-center gap-1 ml-2">
					<div class="w-1.5 h-1.5 rounded-full bg-terminal-green animate-pulse"></div>
					<span class="font-terminal-xs text-[8px] text-terminal-green">ONLINE</span>
				</div>
			</div>
			</div>
		</nav>

		<!-- Main Slot Content -->
		<slot />

		<!-- Bottom Navigation (Mobile Only) -->
		<nav dir="ltr" class="docked full-width bottom-0 z-50 md:hidden bg-surface-container-lowest border-t border-outline-variant bg-opacity-95 backdrop-blur-lg fixed left-0 w-full flex justify-around items-center px-margin-mobile py-2 shadow-lg">
			<a class="flex flex-col items-center justify-center text-neon-blue bg-ghost-blue rounded-xl p-2 scale-90 transition-transform" href="#home">
				<span class="material-symbols-outlined text-neon-blue text-xl" style="font-variation-settings: 'FILL' 1;">home</span>
				<span class="font-label-caps text-[9px] mt-1">HOME</span>
			</a>
			<a class="flex flex-col items-center justify-center text-on-surface-variant p-2 hover:text-neon-blue transition-colors" href="#itinerary">
				<span class="material-symbols-outlined text-on-surface-variant text-xl">event</span>
				<span class="font-label-caps text-[9px] mt-1">SCHEDULE</span>
			</a>
			<a class="flex flex-col items-center justify-center text-on-surface-variant p-2 hover:text-neon-blue transition-colors" href="#lecturer">
				<span class="material-symbols-outlined text-on-surface-variant text-xl">person</span>
				<span class="font-label-caps text-[9px] mt-1">LECTURER</span>
			</a>
		</nav>

		<!-- Footer -->
		<footer dir="ltr" class="w-screen bg-surface-container-lowest border-t border-outline-variant z-10 relative mt-12 mb-16 md:mb-0">
			<div class="flex flex-col md:flex-row justify-between items-center gap-gutter py-8 px-margin-desktop max-w-container-max mx-auto w-full">
			<div class="flex flex-col text-center md:text-left">
				<span class="font-label-caps text-hazard-orange tracking-widest text-sm">OUTPOST 31 FILM SERIES</span>
				<span class="font-terminal-xs text-[10px] text-on-surface-variant opacity-80 mt-1 uppercase">EXPLORING CINEMA BEYOND THE EDGE</span>
			</div>

			<a
				href="https://chat.whatsapp.com/IdrJQ24IP9vF2Owfvu3TGA?mode=gi_t"
				target="_blank"
				rel="noopener noreferrer"
				class="group flex items-center gap-2 border border-terminal-green/30 px-4 py-2 hover:bg-terminal-green/10 hover:border-terminal-green/60 transition-all font-label-caps text-[10px] text-terminal-green tracking-widest uppercase shrink-0"
				aria-label="Join Outpost 31 WhatsApp group"
			>
				<svg class="w-4 h-4 text-terminal-green fill-current group-hover:scale-110 transition-transform" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
					<path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.513 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.66.986 3.284 1.489 4.836 1.49 5.375 0 9.75-4.332 9.752-9.658.001-2.58-1.01-5.005-2.848-6.844S14.075 1.245 11.5 1.245C6.12 1.245 1.748 5.578 1.746 10.905c0 1.602.493 3.167 1.427 4.542l-.993 3.63 3.877-.978zm11.233-5.32c-.105-.175-.385-.262-.77-.455-.385-.193-2.28-1.125-2.63-1.253-.35-.128-.606-.193-.86.193-.255.385-.98 1.253-1.2 1.477-.22.225-.44.248-.825.055-.385-.192-1.625-.6-3.096-1.91-1.144-1.02-1.916-2.28-2.14-2.666-.225-.385-.024-.593.168-.785.174-.173.385-.45.58-.675.19-.225.255-.385.385-.643.13-.257.065-.482-.033-.675-.1-.193-.86-2.074-1.18-2.842-.312-.75-.63-.647-.86-.66-.222-.012-.477-.015-.732-.015-.255 0-.67.096-1.02.482-.35.385-1.336 1.306-1.336 3.183s1.365 3.69 1.558 3.946c.193.257 2.687 4.103 6.51 5.753.91.393 1.62.628 2.172.803.914.29 1.746.248 2.404.15.733-.11 2.28-.93 2.6-1.83.32-.9 0-1.67-.103-1.83z"/>
				</svg>
				<span>JOIN COM-LINK</span>
			</a>
			
			<div class="flex flex-col items-center md:items-end opacity-80 border-t md:border-t-0 md:border-l border-outline-variant/30 pt-4 md:pt-0 md:pl-4 mt-4 md:mt-0">
				<div class="flex gap-1 mb-1 opacity-50">
					<div class="w-px h-3 bg-on-surface-variant"></div>
					<div class="w-px h-3 bg-on-surface-variant"></div>
					<div class="w-0.5 h-3 bg-on-surface-variant"></div>
					<div class="w-px h-3 bg-on-surface-variant"></div>
					<div class="w-1 h-3 bg-on-surface-variant"></div>
					<div class="w-px h-3 bg-on-surface-variant"></div>
				</div>
				<span class="font-terminal-xs text-[8px] text-on-surface-variant text-center md:text-right uppercase">U.S. ANTARCTICA RESEARCH PROGRAM</span>
				<span class="font-terminal-xs text-[8px] text-on-surface-variant text-center md:text-right">STATION 31 --- EST. 1982</span>
			</div>
			</div>
		</footer>

		<!-- WebGL globe animation initialization script -->
		<script is:inline>
			(function(){
				const canvas = document.getElementById('gc');
				if (!canvas) return;
				canvas.width = 64;
				canvas.height = 64;

				const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');
				if(!gl){ return; }

				gl.viewport(0, 0, 64, 64);

				const vs = `
					attribute vec3 pos;
					uniform mat4 mvp;
					void main(){ gl_Position = mvp * vec4(pos,1.0); }
				`;
				const fs = `
					precision mediump float;
					void main(){ gl_FragColor = vec4(0.15, 0.40, 0.99, 1.0); }
				`;

				function compile(type, src){
					const s = gl.createShader(type);
					gl.shaderSource(s, src);
					gl.compileShader(s);
					return s;
				}

				const prog = gl.createProgram();
				gl.attachShader(prog, compile(gl.VERTEX_SHADER, vs));
				gl.attachShader(prog, compile(gl.FRAGMENT_SHADER, fs));
				gl.linkProgram(prog);
				gl.useProgram(prog);

				const posLoc = gl.getAttribLocation(prog, 'pos');
				const mvpLoc = gl.getUniformLocation(prog, 'mvp');

				const lines = [];
				const LAT = 9, LON = 16, R = 1.0;

				for(let i = 0; i <= LAT; i++){
					const phi = Math.PI * (-0.5 + i/LAT);
					const y = Math.sin(phi)*R;
					const r = Math.cos(phi)*R;
					for(let j = 0; j < LON; j++){
						const a0 = 2*Math.PI * j/LON;
						const a1 = 2*Math.PI * (j+1)/LON;
						lines.push(r*Math.cos(a0), y, r*Math.sin(a0));
						lines.push(r*Math.cos(a1), y, r*Math.sin(a1));
					}
				}

				for(let j = 0; j < LON; j++){
					const lon = 2*Math.PI * j/LON;
					const cx = Math.cos(lon), cz = Math.sin(lon);
					for(let i = 0; i < LAT*2; i++){
						const phi0 = Math.PI * (-0.5 + i/(LAT*2));
						const phi1 = Math.PI * (-0.5 + (i+1)/(LAT*2));
						lines.push(Math.cos(phi0)*cx*R, Math.sin(phi0)*R, Math.cos(phi0)*cz*R);
						lines.push(Math.cos(phi1)*cx*R, Math.sin(phi1)*R, Math.cos(phi1)*cz*R);
					}
				}

				const buf = gl.createBuffer();
				gl.bindBuffer(gl.ARRAY_BUFFER, buf);
				gl.bufferData(gl.ARRAY_BUFFER, new Float32Array(lines), gl.STATIC_DRAW);
				gl.enableVertexAttribArray(posLoc);
				gl.vertexAttribPointer(posLoc, 3, gl.FLOAT, false, 0, 0);

				gl.enable(gl.DEPTH_TEST);

				const proj = mat4.create();
				mat4.perspective(proj, 0.9, 1, 0.1, 100);

				const view = mat4.create();
				mat4.translate(view, view, [0, 0, -3.2]);

				const tilt = mat4.create();
				mat4.rotateX(tilt, tilt, 0.3);

				function frame(t){
					gl.clearColor(0.0, 0.0, 0.0, 0.0);
					gl.clear(gl.COLOR_BUFFER_BIT | gl.DEPTH_BUFFER_BIT);

					const rot = mat4.create();
					mat4.rotateY(rot, tilt, t * 0.001);

					const mv = mat4.create();
					mat4.multiply(mv, view, rot);

					const mvp = mat4.create();
					mat4.multiply(mvp, proj, mv);

					gl.uniformMatrix4fv(mvpLoc, false, mvp);
					gl.drawArrays(gl.LINES, 0, lines.length / 3);

					requestAnimationFrame(frame);
				}

				requestAnimationFrame(frame);
			})();
		</script>
	</body>
</html>
